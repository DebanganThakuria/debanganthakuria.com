---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/posts', label: 'Journal' },
  { href: '/novels', label: 'Books' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <a href="/" class="site-logo gradient-text">
    <span class="logo-full">Debangan Thakuria</span>
    <span class="logo-short">Debangan</span>
  </a>

  <nav class="site-nav">
    {navLinks.map((link, i) => {
      const active = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <>
          {i > 0 && <span class="nav-diamond" aria-hidden="true"></span>}
          <a href={link.href} class:list={['nav-link', { active }]}>
            {link.label}
          </a>
        </>
      );
    })}
    <ThemeToggle />
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.75rem 1rem;
    border-bottom: 1px solid var(--color-gold);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--color-gold) 35%, transparent);
  }

  .site-logo {
    font-family: var(--font-family-heading);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .logo-short { display: none; }

  @media (max-width: 600px) {
    .logo-full { display: none; }
    .logo-short { display: inline; }
    .site-header {
      padding: 0.85rem 1rem 0.75rem;
      flex-wrap: wrap;
      column-gap: 1rem;
      row-gap: 0.4rem;
      justify-content: center;
    }
    .site-logo { font-size: 1.15rem; }
    .site-nav { gap: 0.6rem; }
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-diamond {
    width: 5px;
    height: 5px;
    transform: rotate(45deg);
    background: var(--color-gold);
    flex-shrink: 0;
  }

  .nav-link {
    position: relative;
    font-family: var(--font-family-heading);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color 0.15s ease, text-shadow 0.15s ease;
    padding-bottom: 2px;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link.active {
    color: var(--color-coral);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-coral), transparent);
  }

  .nav-link:not(.active):hover::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
  }

  @media (max-width: 600px) {
    .nav-link { font-size: 0.85rem; letter-spacing: 0.06em; }
  }
</style>
