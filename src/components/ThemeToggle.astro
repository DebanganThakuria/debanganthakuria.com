---
---

<button
  id="theme-toggle"
  aria-label="Toggle dark mode"
  class="theme-toggle"
>
  <span id="theme-icon-sun" class="theme-icon hidden" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
    </svg>
  </span>
  <span id="theme-icon-moon" class="theme-icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 12h6v8a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1v-8Z"/><path d="M12 9v3"/><path d="M12 2c1.2 1.4 1.8 2.5 1.8 3.6A1.8 1.8 0 0 1 12 7.4a1.8 1.8 0 0 1-1.8-1.8C10.2 4.5 10.8 3.4 12 2Z"/>
    </svg>
  </span>
</button>

<style>
  .theme-toggle {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    border: 1px solid var(--color-border);
    background: var(--color-parchment-deep);
    color: var(--color-gold);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .theme-toggle:hover {
    color: var(--color-coral);
    border-color: var(--color-coral);
  }

  .theme-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .theme-icon.hidden { display: none; }

  .theme-icon.spin {
    transform: rotate(360deg);
  }
</style>

<script>
  function initTheme() {
    const stored = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = stored === 'dark' || (!stored && prefersDark);
    document.documentElement.classList.toggle('dark', isDark);
    updateIcon(isDark);
  }

  function updateIcon(isDark: boolean) {
    const sun = document.getElementById('theme-icon-sun');
    const moon = document.getElementById('theme-icon-moon');
    if (sun && moon) {
      sun.classList.toggle('hidden', !isDark);
      moon.classList.toggle('hidden', isDark);
    }
  }

  function setupToggle() {
    initTheme();

    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const sun = document.getElementById('theme-icon-sun');
      const moon = document.getElementById('theme-icon-moon');

      // Trigger spin animation
      [sun, moon].forEach(el => {
        if (el) {
          el.classList.remove('spin');
          void el.offsetWidth; // reflow
          el.classList.add('spin');
        }
      });

      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcon(isDark);
    });
  }

  setupToggle();
  document.addEventListener('astro:after-swap', setupToggle);
</script>
