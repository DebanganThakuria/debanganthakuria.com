---
import { candleRead } from '../lib/reading';
import { shortDate } from '../lib/dates';
import { tagChipStyle, primaryInk } from '../lib/tags';

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
  readingTime?: number;
}

const { title, description, date, slug, tags, readingTime } = Astro.props;

const formattedDate = shortDate(date);
const inkColor = primaryInk(tags);
---

<article class="card-lift quest-entry">
  <a href={`/posts/${slug}`} class="quest-link torn" style={`--ink: ${inkColor};`}>
    <span class="quest-diamond" aria-hidden="true"></span>
    <div class="quest-body">
      <div class="quest-head">
        <h2 class="quest-title">{title}</h2>
        <div class="quest-meta">
          {readingTime && <span>{candleRead(readingTime)}</span>}
          <time>{formattedDate}</time>
        </div>
      </div>

      <p class="quest-desc">{description}</p>

      <div class="quest-tags">
        {tags.map(tag => (
          <span class="quest-tag" style={tagChipStyle(tag)}>{tag}</span>
        ))}
      </div>
    </div>
  </a>
</article>

<style>
  .quest-link {
    position: relative;
    display: flex;
    gap: 0.9rem;
    padding: 1.1rem 1.25rem;
    background: var(--color-parchment-deep);
    border: 1px solid var(--color-border);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-parchment) 55%, transparent);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }

  .quest-link:hover {
    border-color: var(--ink);
  }

  .quest-diamond {
    width: 9px;
    height: 9px;
    margin-top: 0.55rem;
    transform: rotate(45deg);
    background: var(--ink);
    border: 1px solid color-mix(in srgb, var(--ink) 55%, var(--color-parchment));
    flex-shrink: 0;
  }

  .quest-body { flex: 1; min-width: 0; }

  .quest-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.35rem;
  }

  .quest-title {
    font-family: var(--font-family-heading);
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0;
  }

  .quest-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
    margin-top: 0.25rem;
    font-size: 0.82rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .quest-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 0.7rem;
  }

  .quest-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .quest-tag {
    font-family: var(--font-family-heading);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.13rem 0.55rem;
    border: 1px solid;
  }

  @media (max-width: 600px) {
    .quest-head { flex-direction: column; gap: 0.15rem; }
    .quest-meta { margin-top: 0; }
  }
</style>
