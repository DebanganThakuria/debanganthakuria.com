---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
  readingTime?: number;
}

const { title, description, date, slug, tags, readingTime } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).format(date);

const tagStyles: Record<string, { bg: string; text: string }> = {
  Tech:    { bg: 'var(--color-tag-tech-bg)',    text: 'var(--color-tag-tech-text)'    },
  Anime:   { bg: 'var(--color-tag-anime-bg)',   text: 'var(--color-tag-anime-text)'   },
  Writing: { bg: 'var(--color-tag-writing-bg)', text: 'var(--color-tag-writing-text)' },
  Life:    { bg: 'var(--color-tag-life-bg)',     text: 'var(--color-tag-life-text)'    },
};

const borderColors: Record<string, string> = {
  Tech:    'var(--color-sky)',
  Anime:   'var(--color-purple)',
  Writing: 'var(--color-sun)',
  Life:    'var(--color-mint)',
};

const primaryTag = tags[0] ?? 'Life';
const borderColor = borderColors[primaryTag] ?? 'var(--color-coral)';
---

<article class="card-lift">
  <a
    href={`/posts/${slug}`}
    class="block rounded-xl p-5"
    style={`background-color: var(--color-surface); border-left: 4px solid ${borderColor};`}
  >
    <div class="flex items-start justify-between gap-4 mb-2">
      <h2
        class="text-lg leading-snug"
        style="font-family: var(--font-family-heading); font-weight: 600; color: var(--color-text);"
      >
        {title}
      </h2>
      <div class="flex items-center gap-2 shrink-0 mt-1">
        {readingTime && <span class="text-xs" style="color: var(--color-text-muted);">{readingTime} min</span>}
        <time class="text-xs" style="color: var(--color-text-muted);">{formattedDate}</time>
      </div>
    </div>

    <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-muted);">{description}</p>

    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => {
        const style = tagStyles[tag] ?? tagStyles['Life'];
        return (
          <span
            class="text-xs px-2.5 py-0.5 rounded-full font-medium"
            style={`background-color: ${style.bg}; color: ${style.text};`}
          >
            {tag}
          </span>
        );
      })}
    </div>
  </a>
</article>
