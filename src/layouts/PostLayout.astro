---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime: number;
  coverImage?: ImageMetadata;
  type?: 'post' | 'photo';
}

const { title, description, date, tags, readingTime, coverImage, type = 'post' } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);

const tagStyles: Record<string, { bg: string; text: string }> = {
  Tech:    { bg: 'var(--color-tag-tech-bg)',    text: 'var(--color-tag-tech-text)'    },
  Anime:   { bg: 'var(--color-tag-anime-bg)',   text: 'var(--color-tag-anime-text)'   },
  Writing: { bg: 'var(--color-tag-writing-bg)', text: 'var(--color-tag-writing-text)' },
  Life:    { bg: 'var(--color-tag-life-bg)',     text: 'var(--color-tag-life-text)'    },
  Travel:  { bg: '#FFE4E4',                      text: 'var(--color-coral)'            },
};
---

<BaseLayout title={title} description={description}>
  <article>
    <!-- Cover image -->
    {coverImage && (
      <div class="mb-10 rounded-2xl overflow-hidden" style="max-height: 420px;">
        <Image
          src={coverImage}
          alt={title}
          class="w-full object-cover"
          style="max-height: 420px;"
          format="webp"
          quality={85}
        />
      </div>
    )}

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4 text-sm" style="color: var(--color-text-muted);">
        <time>{formattedDate}</time>
        <span aria-hidden="true">&middot;</span>
        <span>{readingTime} min read</span>
        {type === 'photo' && (
          <>
            <span aria-hidden="true">&middot;</span>
            <span>📷 photo post</span>
          </>
        )}
      </div>

      <h1 style="font-family: var(--font-family-heading); font-size: 2.25rem; font-weight: 600; line-height: 1.25; color: var(--color-text); margin-bottom: 1rem;">
        {title}
      </h1>

      <p class="text-base mb-4 leading-relaxed" style="color: var(--color-text-muted);">{description}</p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => {
            const style = tagStyles[tag] ?? tagStyles['Life'];
            return (
              <span
                class="text-xs px-2.5 py-0.5 rounded-full font-medium"
                style={`background-color: ${style.bg}; color: ${style.text};`}
              >
                {tag}
              </span>
            );
          })}
        </div>
      )}

      <div class="mt-8 border-t" style="border-color: var(--color-border);"></div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <div class="mt-16 pt-8 border-t" style="border-color: var(--color-border);">
      <a href="/posts" class="text-sm" style="color: var(--color-coral);">&larr; all posts</a>
    </div>
  </article>
</BaseLayout>
