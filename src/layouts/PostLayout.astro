---
import BaseLayout from './BaseLayout.astro';

import TableOfContents from '../components/TableOfContents.astro';
import BackToTop from '../components/BackToTop.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime: number;
  coverImage?: ImageMetadata;
  type?: 'post' | 'photo';
  headings?: { depth: number; slug: string; text: string }[];
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
}

const {
  title, description, date, tags, readingTime, coverImage,
  type = 'post', headings = [], prevPost, nextPost,
} = Astro.props;

// "the 16th of July, 2026" — inscribed the old way
function ordinal(n: number): string {
  const s = ['th', 'st', 'nd', 'rd'];
  const v = n % 100;
  return n + (s[(v - 20) % 10] ?? s[v] ?? s[0]);
}
const day = date.getDate();
const monthYear = new Intl.DateTimeFormat('en-GB', { month: 'long', year: 'numeric' }).format(date);
const formattedDate = `the ${ordinal(day)} of ${monthYear.replace(' ', ', ')}`;

const tagStyles: Record<string, { bg: string; text: string }> = {
  Tech:    { bg: 'var(--color-tag-tech-bg)',    text: 'var(--color-tag-tech-text)'    },
  Anime:   { bg: 'var(--color-tag-anime-bg)',   text: 'var(--color-tag-anime-text)'   },
  Writing: { bg: 'var(--color-tag-writing-bg)', text: 'var(--color-tag-writing-text)' },
  Life:    { bg: 'var(--color-tag-life-bg)',     text: 'var(--color-tag-life-text)'    },
  Travel:  { bg: 'var(--color-tag-writing-bg)',  text: 'var(--color-coral)'            },
};
---

<BaseLayout title={title} description={description}>
  <article>
    <!-- Cover image -->
    {coverImage && (
      <div class="cover-frame mb-10">
        <Image
          src={coverImage}
          alt={title}
          class="w-full object-cover"
          style="max-height: 420px;"
          format="webp"
          quality={85}
        />
      </div>
    )}

    <header class="mb-10">
      <div class="entry-meta">
        <span>Inscribed {formattedDate}</span>
        <span class="meta-diamond" aria-hidden="true"></span>
        <span>a {readingTime}-candle read</span>
        {type === 'photo' && (
          <>
            <span class="meta-diamond" aria-hidden="true"></span>
            <span>an illustrated entry</span>
          </>
        )}
      </div>

      <h1 class="entry-title">{title}</h1>

      <p class="entry-desc">{description}</p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => {
            const style = tagStyles[tag] ?? tagStyles['Life'];
            return (
              <span
                class="entry-tag"
                style={`background-color: ${style.bg}; color: ${style.text}; border-color: color-mix(in srgb, ${style.text} 35%, transparent);`}
              >
                {tag}
              </span>
            );
          })}
        </div>
      )}

      <hr class="rule-diamond" style="margin-bottom: 0;" />
    </header>

    <!-- Table of Contents -->
    <TableOfContents headings={headings} />

    <div class="prose" id="post-content">
      <slot />
    </div>

    <!-- Post navigation -->
    <div class="post-nav">
      {prevPost ? (
        <a href={`/posts/${prevPost.slug}`} class="post-nav-link">
          <span class="post-nav-label">&larr; The preceding entry</span>
          <span class="post-nav-title">{prevPost.title}</span>
        </a>
      ) : <div />}
      {nextPost ? (
        <a href={`/posts/${nextPost.slug}`} class="post-nav-link post-nav-next">
          <span class="post-nav-label">The entry that follows &rarr;</span>
          <span class="post-nav-title">{nextPost.title}</span>
        </a>
      ) : <div />}
    </div>

    <div class="mt-6 mb-2">
      <a href="/posts" class="back-link">&larr; return to the journal</a>
    </div>
  </article>

  <BackToTop />
</BaseLayout>

<style>
  .cover-frame {
    overflow: hidden;
    max-height: 420px;
    border: 1px solid var(--color-gold);
    outline: 1px solid var(--color-gold);
    outline-offset: 4px;
    margin-top: 5px;
    margin-left: 5px;
    margin-right: 5px;
  }

  .entry-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1rem;
    font-size: 0.92rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .meta-diamond {
    width: 4px;
    height: 4px;
    transform: rotate(45deg);
    background: var(--color-gold);
    flex-shrink: 0;
  }

  .entry-title {
    font-family: var(--font-family-heading);
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .entry-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .entry-tag {
    font-family: var(--font-family-heading);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.13rem 0.55rem;
    border: 1px solid;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    background: var(--color-parchment-deep);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .post-nav-link:hover {
    transform: translateY(-2px);
    border-color: var(--color-coral);
  }

  .post-nav-next { text-align: right; }

  .post-nav-label {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .post-nav-title {
    font-family: var(--font-family-heading);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .back-link {
    font-family: var(--font-family-heading);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    color: var(--color-coral);
    text-decoration: none;
  }
  .back-link:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 600px) {
    .post-nav { grid-template-columns: 1fr; }
    .entry-title { font-size: 1.9rem; }
  }
</style>

<!-- Image lightbox script -->
<script>
  function initLightbox() {
    const proseEl = document.getElementById('post-content');
    if (!proseEl) return;

    proseEl.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName !== 'IMG') return;
      const src = (target as HTMLImageElement).src;
      if (!src) return;

      const overlay = document.createElement('div');
      overlay.className = 'image-lightbox';
      overlay.innerHTML = `<img src="${src}" alt="" />`;
      overlay.addEventListener('click', () => overlay.remove());
      document.addEventListener('keydown', function handler(e) {
        if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', handler); }
      });
      document.body.appendChild(overlay);
    });
  }

  initLightbox();
  document.addEventListener('astro:after-swap', initLightbox);
</script>
