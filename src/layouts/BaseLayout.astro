---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Personal site of Debangan Thakuria — backend engineer, anime nerd, and web novel writer.',
  ogImage = '/og-default.png',
} = Astro.props;

const siteUrl = 'https://debanganthakuria.vercel.app';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const pageTitle = title === 'Home' ? 'Debangan Thakuria' : `${title} — Debangan Thakuria`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Debangan Thakuria',
  url: siteUrl,
  jobTitle: 'Backend Software Engineer',
  description: 'Backend engineer, anime nerd, and web novel writer.',
  sameAs: [
    'https://github.com/DebanganThakuria',
    'https://www.linkedin.com/in/debanganthakuria/',
    'https://x.com/DebanganDaemon',
    'https://www.facebook.com/debangan.thakuria',
    'https://www.instagram.com/debangan.thakuria/',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Debangan Thakuria" />
    <meta name="keywords" content="Debangan Thakuria, backend engineer, anime, web novel" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Debangan Thakuria" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@DebanganDaemon" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <ClientRouter />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <AuroraBackground />

    <!-- Aurora visible all around this floating card -->
    <div class="page-wrap">
      <div class="float-card">
        <Header />
        <main id="main-content" class="card-main">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-family-body);
  }

  /* Full-page wrapper — padding lets the smoke show around the panel */
  .page-wrap {
    min-height: 100vh;
    padding: 2.25rem 1.5rem;
    position: relative;
    z-index: 1;
    box-sizing: border-box;
  }

  /* The parchment panel — an Oblivion menu plate with a brass frame */
  .float-card {
    position: relative;
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    background:
      radial-gradient(ellipse at 20% 8%, rgba(140, 110, 60, 0.10), transparent 55%),
      radial-gradient(ellipse at 85% 90%, rgba(120, 90, 45, 0.12), transparent 50%),
      radial-gradient(ellipse at 50% 50%, transparent 60%, rgba(105, 80, 40, 0.14) 100%),
      var(--color-parchment);
    border: 1px solid var(--color-gold);
    border-radius: 2px;
    /* layered brass frame: hairline, gap, heavy band */
    box-shadow:
      0 0 0 3px var(--color-parchment),
      0 0 0 4px var(--color-gold),
      0 0 0 8px rgba(0, 0, 0, 0.0),
      0 18px 60px rgba(0, 0, 0, 0.65);
  }

  /* Corner diamonds on the frame */
  .float-card::before,
  .float-card::after,
  .card-main::before,
  .card-main::after {
    content: '';
    position: absolute;
    width: 10px;
    height: 10px;
    transform: rotate(45deg);
    background: var(--color-gold-bright);
    border: 1px solid var(--color-parchment);
    box-shadow: 0 0 0 1px var(--color-gold);
    z-index: 2;
    pointer-events: none;
  }
  .float-card::before { top: -9px; left: -9px; }
  .float-card::after  { top: -9px; right: -9px; }
  .card-main::before  { bottom: -9px; left: -9px; }
  .card-main::after   { bottom: -9px; right: -9px; }

  :global(html.dark) .float-card {
    background:
      radial-gradient(ellipse at 20% 8%, rgba(220, 180, 100, 0.05), transparent 55%),
      radial-gradient(ellipse at 85% 90%, rgba(200, 160, 80, 0.05), transparent 50%),
      radial-gradient(ellipse at 50% 50%, transparent 60%, rgba(0, 0, 0, 0.3) 100%),
      var(--color-parchment);
    box-shadow:
      0 0 0 3px var(--color-parchment),
      0 0 0 4px var(--color-gold),
      0 18px 60px rgba(0, 0, 0, 0.85);
  }

  .card-main {
    flex: 1;
    padding: 2.5rem 3rem;
  }

  @media (max-width: 600px) {
    .page-wrap { padding: 1rem 0.75rem; }
    .card-main { padding: 2rem 1.5rem; }
  }

  /* Skip to content link */
  .skip-link {
    position: fixed;
    top: -100%;
    left: 1rem;
    z-index: 100;
    padding: 0.5rem 1rem;
    background: var(--color-coral);
    color: #fff;
    border-radius: 0 0 0.5rem 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 0;
  }
</style>
