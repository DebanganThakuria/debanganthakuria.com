---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site of Debangan Thakuria — backend engineer, reader, writer.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — Debangan Thakuria</title>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <AuroraBackground />
    <div class="site-shell">
      <Header />
      <main class="flex-1 max-w-3xl mx-auto w-full px-6 py-14">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-family-body);
  }

  .site-shell {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
    z-index: 0;
  }
</style>
