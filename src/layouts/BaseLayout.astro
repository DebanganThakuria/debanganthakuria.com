---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site of Debangan Thakuria — backend engineer, reader, writer.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — Debangan Thakuria</title>

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <AuroraBackground />

    <!-- Aurora visible all around this floating card -->
    <div class="page-wrap">
      <div class="float-card">
        <Header />
        <main class="card-main">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-family-body);
  }

  /* Full-page wrapper — padding creates aurora margin on all sides */
  .page-wrap {
    min-height: 100vh;
    padding: 2rem 1.25rem;
    position: relative;
    z-index: 1;
    box-sizing: border-box;
  }

  /* The floating card — centered with margin: auto */
  .float-card {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    background: rgba(250, 250, 250, 0.52);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.07);
  }

  :global(html.dark) .float-card {
    background: rgba(15, 15, 26, 0.58);
    border-color: rgba(255, 255, 255, 0.07);
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.35);
  }

  .card-main {
    flex: 1;
    padding: 2.5rem 2rem;
  }

  @media (max-width: 600px) {
    .page-wrap { padding: 1rem 0.75rem; }
    .card-main { padding: 2rem 1.25rem; }
  }
</style>
