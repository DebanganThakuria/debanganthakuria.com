---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { readingTimeMins } from '../../lib/reading';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: sorted[i + 1] ? { title: sorted[i + 1].data.title, slug: sorted[i + 1].id } : undefined,
      nextPost: sorted[i - 1] ? { title: sorted[i - 1].data.title, slug: sorted[i - 1].id } : undefined,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = readingTimeMins(post.body);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  readingTime={readingTime}
  coverImage={post.data.cover_image}
  type={post.data.type}
  headings={headings}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content />
</PostLayout>
