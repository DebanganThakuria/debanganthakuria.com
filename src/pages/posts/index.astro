---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readingTimeMins } from '../../lib/reading';
import { dayMonth } from '../../lib/dates';
import { tagChipStyle, tagColors, primaryInk } from '../../lib/tags';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = ['All', ...Array.from(new Set(sorted.flatMap(p => p.data.tags))).sort()];

const byYear = sorted.reduce<Record<number, typeof sorted>>((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="All Posts" description="Everything Debangan has written — tech, anime, life, writing, and more.">
  <div class="page-header">
    <p class="ui-label kicker">Quest Log</p>
    <h1>The Journal</h1>
    <p class="subtitle"><span id="post-count">{sorted.length}</span> entries — everything, in order</p>
  </div>

  <!-- Filter tabs -->
  <div class="filter-row">
    {allTags.map((tag, i) => (
      <button
        data-tag={tag}
        data-accent={tag === 'All' ? 'var(--color-coral)' : tagColors(tag).ink}
        style={i === 0 ? 'color: var(--color-coral); border-color: var(--color-coral);' : undefined}
        class="filter-tab"
      >
        {tag}
      </button>
    ))}
  </div>

  <!-- Timeline -->
  <div class="timeline" id="timeline">
    {years.map(year => (
      <div data-year-block class="year-block">
        <div class="year-label">
          <span class="gradient-text">{year}</span>
        </div>

        <div class="year-entries">
          {byYear[year].map(post => (
            <div data-tags={post.data.tags.join(',')} data-entry class="timeline-entry">
              <div class="timeline-dot" style={`background: ${primaryInk(post.data.tags)};`}></div>
              <a href={`/posts/${post.id}`} class="entry-card torn">
                <div class="entry-head">
                  <h2 class="entry-title">{post.data.title}</h2>
                  <span class="entry-meta">
                    <span>{readingTimeMins(post.body)}-candle</span>
                    <time>{dayMonth(post.data.date)}</time>
                  </span>
                </div>

                <p class="entry-desc">{post.data.description}</p>

                <div class="entry-tags">
                  {post.data.tags.map(tag => (
                    <span class="entry-tag" style={tagChipStyle(tag)}>{tag}</span>
                  ))}
                  {post.data.type === 'photo' && (
                    <span class="entry-tag" style={tagChipStyle('Writing')}>illustrated</span>
                  )}
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header { margin-bottom: 2rem; }

  .kicker {
    font-size: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .page-header h1 {
    font-family: var(--font-family-heading);
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .filter-tab {
    font-family: var(--font-family-heading);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.95rem;
    background: var(--color-parchment-deep);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.12s ease, border-color 0.12s ease;
  }

  .filter-tab:hover { color: var(--color-text); }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .year-block {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 0 1.5rem;
    align-items: start;
  }

  .year-label {
    padding-top: 0.2rem;
    text-align: right;
    font-family: var(--font-family-heading);
    font-size: 1.5rem;
  }

  .year-entries {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-border);
  }

  .timeline-entry {
    position: relative;
    display: flex;
    align-items: flex-start;
  }

  .timeline-dot {
    position: absolute;
    left: -1.55rem;
    top: 1.05rem;
    width: 11px;
    height: 11px;
    transform: rotate(45deg);
    border: 1px solid var(--color-parchment);
    flex-shrink: 0;
    box-shadow: 0 0 0 1px var(--color-gold);
  }

  /* Pulse on the first (latest) diamond */
  [data-year-block]:first-child [data-entry]:first-child .timeline-dot {
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 1px var(--color-gold); }
    50%      { box-shadow: 0 0 0 3px var(--color-gold); }
  }

  .entry-card {
    display: block;
    width: 100%;
    background-color: var(--color-parchment-deep);
    border: 1px solid var(--color-border);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-parchment) 55%, transparent);
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .entry-card:hover {
    transform: translateX(5px);
    border-color: var(--color-coral);
  }

  .entry-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .entry-title {
    font-family: var(--font-family-heading);
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-text);
    margin: 0;
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
    font-size: 0.8rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .entry-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    color: var(--color-text-muted);
  }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .entry-tag {
    font-family: var(--font-family-heading);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.13rem 0.55rem;
    border: 1px solid;
  }

  @media (max-width: 600px) {
    .year-block { grid-template-columns: 48px 1fr; gap: 0 1rem; }
    .year-label { font-size: 1.15rem; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const entries = document.querySelectorAll<HTMLElement>('[data-entry]');
  const yearBlocks = document.querySelectorAll<HTMLElement>('[data-year-block]');
  const countEl = document.getElementById('post-count');

  function setTabStyle(btn: HTMLButtonElement, active: boolean) {
    const accent = btn.dataset.accent ?? 'var(--color-coral)';
    if (active) {
      btn.style.color = accent;
      btn.style.borderColor = accent;
    } else {
      btn.style.color = '';
      btn.style.borderColor = '';
    }
  }

  function filter(tag: string) {
    let visible = 0;

    entries.forEach(entry => {
      const tags = (entry.dataset.tags ?? '').split(',');
      const show = tag === 'All' || tags.includes(tag);
      entry.style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });

    yearBlocks.forEach(block => {
      const anyVisible = [...block.querySelectorAll<HTMLElement>('[data-entry]')]
        .some(e => e.style.display !== 'none');
      block.style.display = anyVisible ? 'grid' : 'none';
    });

    if (countEl) countEl.textContent = String(visible);
    tabs.forEach(t => setTabStyle(t, t.dataset.tag === tag));
  }

  tabs.forEach(tab => tab.addEventListener('click', () => filter(tab.dataset.tag ?? 'All')));
</script>
