---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = ['All', ...Array.from(new Set(sorted.flatMap(p => p.data.tags))).sort()];

const byYear = sorted.reduce<Record<number, typeof sorted>>((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const tagDotColors: Record<string, string> = {
  Tech:    'var(--color-sky)',
  Anime:   'var(--color-purple)',
  Writing: 'var(--color-sun)',
  Life:    'var(--color-mint)',
  Travel:  'var(--color-coral)',
};

const tagTextColors: Record<string, string> = {
  Tech:    'var(--color-tag-tech-text)',
  Anime:   'var(--color-tag-anime-text)',
  Writing: 'var(--color-tag-writing-text)',
  Life:    'var(--color-tag-life-text)',
  Travel:  'var(--color-coral)',
};

const tagBgs: Record<string, string> = {
  Tech:    'var(--color-tag-tech-bg)',
  Anime:   'var(--color-tag-anime-bg)',
  Writing: 'var(--color-tag-writing-bg)',
  Life:    'var(--color-tag-life-bg)',
  Travel:  '#FFE4E4',
};

const tabAccents: Record<string, string> = {
  All:     'var(--color-coral)',
  Tech:    'var(--color-sky)',
  Anime:   'var(--color-purple)',
  Writing: 'var(--color-sun)',
  Life:    'var(--color-mint)',
  Travel:  'var(--color-coral)',
};
---

<BaseLayout title="All Posts" description="Everything Debangan has written — tech, anime, life, writing, and more.">
  <div style="margin-bottom:2rem;">
    <p class="ui-label" style="font-size:0.75rem; margin-bottom:0.5rem;">Quest Log</p>
    <h1 style="font-family:var(--font-family-heading); font-size:2.4rem; font-weight:400; color:var(--color-text); margin-bottom:0.5rem;">
      The Journal
    </h1>
    <p style="font-size:1rem; font-style:italic; color:var(--color-text-muted);">
      <span id="post-count">{sorted.length}</span> entries — everything, in order
    </p>
  </div>

  <!-- Filter tabs -->
  <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2.5rem;">
    {allTags.map((tag, i) => (
      <button
        data-tag={tag}
        data-accent={tabAccents[tag] ?? 'var(--color-coral)'}
        style={i === 0
          ? `color:${tabAccents[tag]};border-color:${tabAccents[tag]};`
          : undefined
        }
        class="filter-tab"
      >
        {tag}
      </button>
    ))}
  </div>

  <!-- Timeline -->
  <div style="display:flex; flex-direction:column; gap:3rem;" id="timeline">
    {years.map(year => (
      <div data-year-block style="display:grid; grid-template-columns:72px 1fr; gap:0 1.5rem; align-items:start;">
        <div style="padding-top:0.2rem; text-align:right;">
          <span class="gradient-text" style="font-family:var(--font-family-heading); font-size:1.5rem; font-weight:600;">
            {year}
          </span>
        </div>

        <div style="position:relative; display:flex; flex-direction:column; gap:1rem; padding-left:1.5rem; border-left:2px solid var(--color-border);">
          {byYear[year].map(post => {
            const primaryTag = post.data.tags[0] ?? 'Life';
            const dotColor = tagDotColors[primaryTag] ?? 'var(--color-coral)';
            const month = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short' }).format(post.data.date);
            const words = post.body?.split(/\s+/).length ?? 0;
            const mins = Math.max(1, Math.round(words / 200));
            return (
              <div data-tags={post.data.tags.join(',')} data-entry style="position:relative; display:flex; align-items:flex-start;">
                <div class="timeline-dot" style={`background:${dotColor};`}></div>
                <a
                  href={`/posts/${post.id}`}
                  class="entry-card"
                >
                  <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.75rem; margin-bottom:0.25rem;">
                    <h2 style="font-family:var(--font-family-heading); font-size:1.15rem; font-weight:400; line-height:1.4; color:var(--color-text); margin:0;">
                      {post.data.title}
                    </h2>
                    <span style="font-size:0.8rem; font-style:italic; flex-shrink:0; margin-top:0.125rem; color:var(--color-text-muted); display:flex; align-items:center; gap:0.5rem;">
                      <span>{mins}-candle</span>
                      <time>{month}</time>
                    </span>
                  </div>

                  <p style="font-size:0.9rem; line-height:1.6; margin-bottom:0.75rem; color:var(--color-text-muted);">{post.data.description}</p>

                  <div style="display:flex; flex-wrap:wrap; gap:0.375rem;">
                    {post.data.tags.map(tag => (
                      <span class="entry-tag" style={`background-color:${tagBgs[tag] ?? 'var(--color-surface)'}; color:${tagTextColors[tag] ?? 'var(--color-text)'}; border-color:color-mix(in srgb, ${tagTextColors[tag] ?? 'var(--color-text)'} 35%, transparent);`}>
                        {tag}
                      </span>
                    ))}
                    {post.data.type === 'photo' && (
                      <span class="entry-tag" style="background-color:var(--color-tag-writing-bg); color:var(--color-sun); border-color:color-mix(in srgb, var(--color-sun) 35%, transparent);">
                        illustrated
                      </span>
                    )}
                  </div>
                </a>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .timeline-dot {
    position: absolute;
    left: -1.55rem;
    top: 1.05rem;
    width: 11px;
    height: 11px;
    transform: rotate(45deg);
    border: 1px solid var(--color-parchment);
    flex-shrink: 0;
    box-shadow: 0 0 0 1px var(--color-gold);
  }

  /* Pulse on the first (latest) diamond */
  [data-year-block]:first-child [data-entry]:first-child .timeline-dot {
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 1px var(--color-gold); }
    50%      { box-shadow: 0 0 0 3px var(--color-gold); }
  }

  .filter-tab {
    font-family: var(--font-family-heading);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    background: var(--color-parchment-deep);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: color 0.12s ease, border-color 0.12s ease;
  }

  .filter-tab:hover { color: var(--color-text); }

  :global(.entry-card) {
    display: block;
    width: 100%;
    background-color: var(--color-parchment-deep);
    border: 1px solid var(--color-border);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-parchment) 55%, transparent);
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  :global(.entry-card:hover) {
    transform: translateX(5px);
    border-color: var(--color-coral);
  }

  :global(.entry-tag) {
    font-family: var(--font-family-heading);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.13rem 0.55rem;
    border: 1px solid;
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const entries = document.querySelectorAll<HTMLElement>('[data-entry]');
  const yearBlocks = document.querySelectorAll<HTMLElement>('[data-year-block]');
  const countEl = document.getElementById('post-count');

  function setTabStyle(btn: HTMLButtonElement, active: boolean) {
    const accent = btn.dataset.accent ?? 'var(--color-coral)';
    if (active) {
      btn.style.color = accent;
      btn.style.borderColor = accent;
    } else {
      btn.style.color = '';
      btn.style.borderColor = '';
    }
  }

  function filter(tag: string) {
    let visible = 0;

    entries.forEach(entry => {
      const tags = (entry.dataset.tags ?? '').split(',');
      const show = tag === 'All' || tags.includes(tag);
      (entry as HTMLElement).style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });

    yearBlocks.forEach(block => {
      const anyVisible = [...block.querySelectorAll<HTMLElement>('[data-entry]')]
        .some(e => e.style.display !== 'none');
      (block as HTMLElement).style.display = anyVisible ? 'grid' : 'none';
    });

    if (countEl) countEl.textContent = String(visible);
    tabs.forEach(t => setTabStyle(t, t.dataset.tag === tag));
  }

  tabs.forEach(tab => tab.addEventListener('click', () => filter(tab.dataset.tag ?? 'All')));
</script>
