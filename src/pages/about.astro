  {
    label: 'socials',
    links: [
      { label: 'Facebook',   handle: 'debangan.thakuria',   href: 'https://www.facebook.com/debangan.thakuria',          color: '#1877F2', darkColor: '#5a9bf5', icon: icon.facebook   },
      { label: 'Instagram',  handle: '@debangan.thakuria',  href: 'https://www.instagram.com/debangan.thakuria/',        color: '#E1306C', darkColor: '#f77ab2', icon: icon.instagram  },
      { label: 'X / Twitter',handle: '@DebanganDaemon',     href: 'https://x.com/DebanganDaemon',                       color: '#000000', darkColor: '#e7e9ea', icon: icon.x          },
