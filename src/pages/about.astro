---
import BaseLayout from '../layouts/BaseLayout.astro';

const currently = [
  { icon: '📖', label: 'Reading', value: 'Whatever web novel has pulled me in this week', color: 'var(--color-purple)' },
  { icon: '📺', label: 'Watching', value: 'Keeping up with the current anime season', color: 'var(--color-coral)' },
  { icon: '✍️', label: 'Writing', value: 'My web novel, slowly and steadily', color: 'var(--color-mint)' },
  { icon: '💻', label: 'Working on', value: 'Backend infrastructure, distributed systems', color: 'var(--color-sky)' },
];
---

<BaseLayout title="About" description="A bit about Debangan Thakuria — backend engineer, reader, writer, and fish keeper.">
  <article>
    <div class="mb-8">
      <span class="text-4xl" aria-hidden="true">🙂</span>
    </div>

    <h1 class="text-4xl mb-8" style="font-family: var(--font-family-heading); font-weight: 600; color: var(--color-text);">
      about <span class="gradient-text">me</span>
    </h1>

    <div class="prose mb-14">
      <p>
        I'm Debangan — a backend software engineer with about four and a half years of experience,
        mostly in distributed systems and API design. I like building things that are simple, correct,
        and boring in the best possible way.
      </p>

      <p>
        I'm also a reader. I grew up on manga and light novels, and somewhere along the way that
        expanded into web novels and the occasional fantasy or sci-fi epic. The stories I gravitate
        towards tend to be long, unhurried, and character-driven — the kind where you spend a hundred
        chapters just learning to care about people.
      </p>

      <p>
        I've been writing my own web novel for a while. Slowly, which is fine. Writing that way feels
        more honest.
      </p>

      <p>
        Outside of that: I go to the gym, I keep fish (currently a betta and a peaceful community
        tank), and I tend to prefer small spaces, quiet evenings, and very good tea.
      </p>

      <p>
        This site is a place to write things I'd otherwise lose to scattered notes. No theme, no
        niche — just whatever's on my mind.
      </p>
    </div>

    <!-- Currently -->
    <div>
      <h2 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
        currently
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {currently.map(item => (
          <div
            class="card-lift rounded-xl p-4 flex gap-3 items-start"
            style="background-color: var(--color-surface);"
          >
            <span class="text-xl mt-0.5" aria-hidden="true">{item.icon}</span>
            <div>
              <div class="text-xs font-semibold uppercase tracking-wide mb-1" style={`color: ${item.color};`}>
                {item.label}
              </div>
              <div class="text-sm leading-relaxed" style="color: var(--color-text);">
                {item.value}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </article>
</BaseLayout>
