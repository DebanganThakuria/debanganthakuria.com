const groups = [
  {
    label: 'socials',
    links: [
      { label: 'Facebook',    href: 'https://www.facebook.com/debangan.thakuria',          color: '#1877F2', darkColor: '#5a9bf5', icon: icon.facebook   },
      { label: 'Instagram',   href: 'https://www.instagram.com/debangan.thakuria/',        color: '#E1306C', darkColor: '#f77ab2', icon: icon.instagram  },
      { label: 'X / Twitter', href: 'https://x.com/DebanganDaemon',                       color: '#000000', darkColor: '#e7e9ea', icon: icon.x          },
      { label: 'LinkedIn',    href: 'https://www.linkedin.com/in/debanganthakuria/',       color: '#0A66C2', darkColor: '#5aabff', icon: icon.linkedin   },
      { label: 'GitHub',      href: 'https://github.com/DebanganThakuria',                color: '#24292e', darkColor: '#e6edf3', icon: icon.github     },
    ],
  },
  {
    label: 'writing',
    links: [
      { label: 'Royal Road',   href: 'https://www.royalroad.com/profile/92138',              color: '#F7A324', darkColor: '#fbbf5a', icon: icon.royalroad   },
      { label: 'Scribble Hub', href: 'https://www.scribblehub.com/profile/233414/devanvale/', color: '#E8612C', darkColor: '#f4956a', icon: icon.scribblehub },
      { label: 'Webnovel',     href: 'https://www.webnovel.com/profile/4310972715',           color: '#FF7B00', darkColor: '#ffaa55', icon: icon.webnovel    },
    ],
  },
];
---

<BaseLayout title="Home" description="Personal site of Debangan Thakuria — backend engineer, reader, writer.">

  <!-- Intro -->
  <section class="mb-10">
    <div class="mb-6">
      <div class="mb-2">
        <span class="wiggle text-3xl" aria-hidden="true">👋</span>
      </div>
      <h1 class="text-4xl sm:text-5xl mb-3 leading-tight" style="font-family: var(--font-family-heading); font-weight: 600; color: var(--color-text);">
        hey, i'm <span class="gradient-text">debangan.</span>
      </h1>
      <p class="text-base" style="color: var(--color-text-muted);">
        backend engineer ·
        <span style="color: var(--color-purple);">anime nerd</span> ·
        <span style="color: var(--color-mint);">web novel writer</span>
      </p>
    </div>

    <!-- Bio -->
    <div class="prose">
      <p>
        I'm a backend software engineer with about four and a half years of experience, mostly in
        distributed systems and API design. I like building things that are simple, correct, and
        boring in the best possible way.
      </p>
      <p>
        I'm also a reader. I grew up on Hardy Boys, Nancy Drew, Famous Five, Agatha Christie,
        Goosebumps — the usual suspects. Somewhere along the way that expanded into manga and light
        novels, then web novels and the occasional fantasy or sci-fi epic. The stories I gravitate
        towards tend to feature capable protagonists who try to do the right thing, even when it's
        hard. You might know the term <em>competency porn</em> — that's exactly it. Characters who
        are genuinely good at what they do, and watching them grow and navigate the world is the
        whole point.
      </p>
      <p>
        I've recently started writing my own web novel. Slowly, which is fine — it's as much about
        learning to write and tell stories as it is about finishing anything.
      </p>
      <p>
        Outside of all that: I go to the gym, keep up with global news, watch anime and the
        occasional fantasy show or film. I tend to prefer warm spaces, cosy evenings, and very
        good tea.
      </p>
      <p>
        This site is a place to put down things I'd otherwise lose to scattered notes. No theme,
        no niche — just whatever's on my mind.
      </p>
    </div>

    <!-- Social icons -->
    <div class="flex flex-col gap-3 mt-8">
      {groups.map(group => (
        <div class="flex flex-wrap gap-2">
          {group.links.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-chip"
              style={`--brand: ${s.color}; --brand-dark: ${s.darkColor};`}
              title={s.label}
            >
              <span class="chip-icon" set:html={s.icon} />
              <span class="chip-label">{s.label}</span>
            </a>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <hr class="section-divider" />

  <!-- Recent posts -->
  <section class="mt-10">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">
        recent posts
      </h2>
      <a href="/posts" class="text-xs font-medium" style="color: var(--color-coral);">
        all posts →
      </a>
    </div>

    {recentPosts.length === 0 ? (
      <p style="color: var(--color-text-muted);">Nothing here yet — check back soon.</p>
    ) : (
      <div class="flex flex-col gap-3">
        {recentPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .section-divider {
    border: none;
    border-top: 1px solid var(--color-border);
  }

  /* Social icon chips */
  .social-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem 0.35rem 0.45rem;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: transform 0.12s ease, border-color 0.12s ease;
  }

  .social-chip:hover {
    transform: translateY(-2px);
    border-color: var(--brand);
  }

  .chip-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    flex-shrink: 0;
  }

  .chip-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text);
    white-space: nowrap;
  }

  :global(html.dark) .chip-icon {
    background: transparent;
    color: var(--brand-dark);
    border: 1px solid var(--brand-dark);
  }

  :global(html.dark) .social-chip:hover {
    border-color: var(--brand-dark);
  }
</style>
