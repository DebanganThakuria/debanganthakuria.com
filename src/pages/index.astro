---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

// Profile image — drop your photo at src/assets/images/me.png
const profileGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/images/me.{png,jpg,jpeg,webp}', { eager: true });
const profileImage = Object.values(profileGlob)[0]?.default;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const allNovels = await getCollection('novels');
const allNovelChapters = await getCollection('chapters');
const novels = allNovels.slice(0, 4).map(novel => ({
  ...novel,
  chapterCount: allNovelChapters.filter(c => c.data.novel === novel.id).length,
}));

const icon = {
  facebook:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  github:     `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  linkedin:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  x:          `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.727-8.857L1.999 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  instagram:  `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  royalroad:  `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L3 7v10l9 5 9-5V7L12 2zm0 2.18L19 8v.93l-7 3.89-7-3.89V8l7-3.82zM5 9.87l7 3.89 7-3.89V17l-7 3.89L5 17V9.87z"/></svg>`,
  scribblehub:`<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.9 3.1a4.27 4.27 0 0 0-6 0l-1.5 1.5 6 6 1.5-1.5a4.27 4.27 0 0 0 0-6zM3 13.4V19h5.6L19 8.6l-5.6-5.6L3 13.4zm2 2.18 8.6-8.6 1.42 1.42L6.42 18.6H5v-3z"/></svg>`,
  webnovel:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zM6 4h5v8l-2.5-1.5L6 12V4zm12 16H6v-2h12v2zm0-4H6v-2h12v2zm0-4h-5V4h5v8z"/></svg>`,
};

const groups = [
  {
    label: 'socials',
    links: [
      { label: 'Facebook',    href: 'https://www.facebook.com/debangan.thakuria',          color: '#1877F2', darkColor: '#5a9bf5', icon: icon.facebook   },
      { label: 'Instagram',   href: 'https://www.instagram.com/debangan.thakuria/',        color: '#E1306C', darkColor: '#f77ab2', icon: icon.instagram  },
      { label: 'X / Twitter', href: 'https://x.com/DebanganDaemon',                       color: '#000000', darkColor: '#e7e9ea', icon: icon.x          },
      { label: 'LinkedIn',    href: 'https://www.linkedin.com/in/debanganthakuria/',       color: '#0A66C2', darkColor: '#5aabff', icon: icon.linkedin   },
      { label: 'GitHub',      href: 'https://github.com/DebanganThakuria',                color: '#24292e', darkColor: '#e6edf3', icon: icon.github     },
    ],
  },
  {
    label: 'writing',
    links: [
      { label: 'Royal Road',   href: 'https://www.royalroad.com/profile/92138',              color: '#F7A324', darkColor: '#fbbf5a', icon: icon.royalroad   },
      { label: 'Scribble Hub', href: 'https://www.scribblehub.com/profile/233414/devanvale/', color: '#E8612C', darkColor: '#f4956a', icon: icon.scribblehub },
      { label: 'Webnovel',     href: 'https://www.webnovel.com/profile/4310972715',           color: '#FF7B00', darkColor: '#ffaa55', icon: icon.webnovel    },
    ],
  },
];
---

<BaseLayout title="Home" description="Personal site of Debangan Thakuria — backend engineer, reader, writer.">

  <!-- Intro -->
  <section class="mb-10">
    <div class="intro-row">
      {profileImage ? (
        <div class="profile-photo">
          <Image src={profileImage} alt="Debangan Thakuria" width={128} height={128} class="profile-img" format="webp" quality={85} />
        </div>
      ) : (
        <div class="profile-photo profile-initials" aria-hidden="true">DT</div>
      )}
      <div class="intro-text">
        <div class="mb-1">
          <span class="wiggle text-2xl" aria-hidden="true">👋</span>
        </div>
        <h1 class="text-3xl sm:text-4xl mb-2 leading-tight" style="font-family: var(--font-family-heading); font-weight: 600; color: var(--color-text);">
          hey, i'm <span class="gradient-text">debangan.</span>
        </h1>
        <p class="text-sm" style="color: var(--color-text-muted);">
          backend engineer ·
          <span style="color: var(--color-purple);">anime nerd</span> ·
          <span style="color: var(--color-mint);">web novel writer</span>
        </p>
      </div>
    </div>

    <!-- Bio — condensed -->
    <div class="prose mt-5">
      <p>
        I'm a backend software engineer with about four and a half years of experience, mostly in
        distributed systems and API design. I like building things that are simple, correct, and
        boring in the best possible way.
      </p>
      <p>
        Outside of work, I go to the gym, keep up with global news, watch anime and the
        occasional fantasy show or film. I tend to prefer warm spaces, cosy evenings, and very
        good tea.
      </p>
      <p>
        This site is a place to put down things I'd otherwise lose to scattered notes. No theme,
        no niche — just whatever's on my mind.
      </p>
    </div>

    <!-- Read more -->
    <details class="bio-details mt-2">
      <summary class="bio-summary">more about me</summary>
      <div class="prose mt-3">
        <p>
          I'm also a reader. I grew up on Hardy Boys, Nancy Drew, Famous Five, Agatha Christie,
          Goosebumps — the usual suspects. Somewhere along the way that expanded into manga and light
          novels, then web novels and the occasional fantasy or sci-fi epic. The stories I gravitate
          towards tend to feature capable protagonists who try to do the right thing, even when it's
          hard. You might know the term <em>competency porn</em> — that's exactly it. Characters who
          are genuinely good at what they do, and watching them grow and navigate the world is the
          whole point.
        </p>
        <p>
          I've recently started writing my own web novel. Slowly, which is fine — it's as much about
          learning to write and tell stories as it is about finishing anything.
        </p>
      </div>
    </details>

    <!-- Social icons -->
    <div class="flex flex-col gap-3 mt-6">
      {groups.map(group => (
        <div class="social-row">
          {group.links.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-chip"
              style={`--brand: ${s.color}; --brand-dark: ${s.darkColor};`}
              title={s.label}
            >
              <span class="chip-icon" set:html={s.icon} />
              <span class="chip-label">{s.label}</span>
            </a>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <hr class="section-divider" />

  <!-- Recent posts -->
  <section class="mt-10">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">
        recent posts
      </h2>
      <a href="/posts" class="text-xs font-medium" style="color: var(--color-coral);">
        all posts →
      </a>
    </div>

    {recentPosts.length === 0 ? (
      <p style="color: var(--color-text-muted);">Nothing here yet — check back soon.</p>
    ) : (
      <div class="flex flex-col gap-3">
        {recentPosts.map((post, i) => {
          const words = post.body?.split(/\s+/).length ?? 0;
          const readingTime = Math.max(1, Math.round(words / 200));
          return (
            <div class="card-enter" style={`animation-delay: ${i * 0.07}s;`}>
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                slug={post.id}
                tags={post.data.tags}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
    )}
  </section>

  <!-- Divider -->
  <hr class="section-divider" style="margin-top: 2.5rem;" />

  <!-- Webnovels section -->
  <section class="mt-10">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">
        webnovels
      </h2>
      <a href="/novels" class="text-xs font-medium" style="color: var(--color-coral);">
        all novels →
      </a>
    </div>

    <div class="novels-preview-grid">
      {novels.map(novel => (
        <a href={`/novels/${novel.id}`} class="novel-preview-card">
          <div class="novel-preview-body">
            <h3 class="novel-preview-title">{novel.data.title}</h3>
            <p class="novel-preview-desc">{novel.data.description}</p>
            <div class="novel-preview-footer">
              <span class="novel-preview-genre">{novel.data.genre[0]}</span>
              <span class="novel-preview-chapters">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                {novel.chapterCount} ch
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .section-divider {
    border: none;
    border-top: 1px solid var(--color-border);
  }

  /* Intro row with photo */
  .intro-row {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .profile-photo {
    width: 128px;
    height: 128px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 3px solid var(--color-border);
  }

  .profile-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-family-heading);
    font-size: 1.75rem;
    font-weight: 600;
    background: linear-gradient(135deg, var(--color-coral), var(--color-purple));
    color: #fff;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 600px) {
    .intro-row { gap: 1rem; }
    .profile-photo { width: 96px; height: 96px; }
  }

  /* Bio details/summary */
  .bio-details { border: none; }
  .bio-summary {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-coral);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .bio-summary::-webkit-details-marker { display: none; }
  .bio-summary::before { content: '+ '; }
  .bio-details[open] .bio-summary::before { content: '− '; }

  /* Social icon chips */
  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .social-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem 0.35rem 0.45rem;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: transform 0.12s ease, border-color 0.12s ease;
  }

  .social-chip:hover {
    transform: translateY(-2px);
    border-color: var(--brand);
  }

  .chip-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    flex-shrink: 0;
  }

  .chip-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text);
    white-space: nowrap;
  }

  :global(html.dark) .chip-icon {
    background: transparent;
    color: var(--brand-dark);
    border: 1px solid var(--brand-dark);
  }

  :global(html.dark) .social-chip:hover {
    border-color: var(--brand-dark);
  }

  /* Mobile: icon-only social chips */
  @media (max-width: 600px) {
    .social-row { gap: 0.4rem; }
    .chip-label { display: none; }
    .social-chip { padding: 0.35rem; }
  }

  /* Webnovels preview grid */
  .novels-preview-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .novel-preview-card {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.1rem;
    border-radius: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .novel-preview-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
    border-color: var(--color-coral);
  }

  :global(html.dark) .novel-preview-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .novel-preview-body { flex: 1; }

  .novel-preview-title {
    font-family: var(--font-family-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 0.35rem;
  }

  .novel-preview-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 0.6rem;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .novel-preview-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .novel-preview-genre {
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-sage) 15%, transparent);
    color: var(--color-sage);
  }

  .novel-preview-chapters {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 600px) {
    .novels-preview-grid { grid-template-columns: 1fr; }
  }
</style>
